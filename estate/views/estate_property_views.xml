<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- =========================== -->
    <!-- LIST VIEW                  -->
    <!-- =========================== -->
    <record id="view_estate_property_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list string="Properties" create="true" edit="true" delete="true">
                <field name="name" string="Property"/>
                <field name="expected_price" string="Expected Price"/>
                <field name="state" string="Status" widget="badge"/>
                <field name="bedrooms" string="Beds"/>
                <field name="living_area" string="Area (sqm)"/>
                <field name="garage" string="Garage"/>
                <field name="garden" string="Garden"/>
                <field name="date_availability" string="Available From"/>
                <field name="tag_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <!-- =========================== -->
    <!-- SEARCH VIEW                -->
    <!-- =========================== -->
    <record id="view_estate_property_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search string="Search Properties">
                <!-- Searchable Fields -->
                <field name="name" string="Property Name"/>
                <field name="postcode"/>
                <field name="expected_price" string="Price"/>
                <field name="state"/>
                <field name="property_type_id"/>
                <field name="tag_ids"/>
                <field name="bedrooms"/>
                <field name="offer_ids" string="Offers"/>
                
                <!-- Filters -->
                <filter name="available"
                        string="Available"
                        domain="[('state', 'in', ['new', 'offer_received'])]"/>
                <filter name="sold"
                        string="Sold"
                        domain="[('state', '=', 'sold')]"/>
                <filter name="new"
                        string="New"
                        domain="[('state', '=', 'new')]"/>
                <filter name="with_garage"
                        string="With Garage"
                        domain="[('garage', '=', True)]"/>
                <filter name="with_garden"
                        string="With Garden"
                        domain="[('garden', '=', True)]"/>
                <filter name="high_price"
                        string="High Price (&gt;500,000)"
                        domain="[('expected_price', '&gt;', 500000)]"/>
                <filter name="low_price"
                        string="Low Price (&lt;100,000)"
                        domain="[('expected_price', '&lt;', 100000)]"/>

                <!-- Group By -->
                <filter name="group_by_state"
                        string="Group by Status"
                        context="{'group_by': 'state'}"/>
                <filter name="group_by_type"
                        string="Group by Property Type"
                        context="{'group_by': 'property_type_id'}"/>
                <filter name="group_by_bedrooms"
                        string="Group by Bedrooms"
                        context="{'group_by': 'bedrooms'}"/>
                <filter name="group_by_availability"
                        string="Group by Availability"
                        context="{'group_by': 'date_availability'}"/>
                <filter name="group_by_postcode"
                        string="Group by Postcode"
                        context="{'group_by': 'postcode'}"/>
            </search>
        </field>
    </record>

    <!-- =========================== -->
    <!-- FORM VIEW                  -->
    <!-- =========================== -->
    <record id="view_estate_property_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Properties">
            <header>
                <button name="action_sold"
                        string="SOLD"
                        type="object"
                        class="btn-primary"
                        invisible="not id or state in ('sold','canceled')"/>
                
                <button name="action_cancel"
                        string="CANCEL"
                        type="object"
                        class="btn-danger"
                        invisible="not id or state in ('sold','canceled')"/>
                
                <field name="state" widget="statusbar"
                    statusbar_visible="new,offer_received,offer_accepted,sold,canceled"/>
            </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Property Name..."/>
                        </h1>
                        <div class="o_row mb16">
                            <field name="tag_ids" widget="many2many_tags" 
                                options="{'color_field': 'color', 'no_create': False}"/>
                        </div>
                    </div>

                    <group>
                        <group>
                            <field name="postcode" placeholder="Postcode..."/>
                            <field name="date_availability"/>
                            <field name="property_type_id"/>
                            <field name="state" widget="selection" readonly="1"/>
                        </group>
                        <group>
                            <field name="expected_price" widget="monetary"/>
                            <field name="best_offer" widget="monetary" readonly="1"/>
                            <field name="selling_price" widget="monetary" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- TAB 1: Description -->
                        <page string="Description">
                            <group>
                                <field name="description" placeholder="Description..." nolabel="1"/>
                            </group>
                            <group string="Property Details">
                                <group>
                                    <field name="bedrooms"/>
                                    <field name="living_area"/>
                                    <field name="facades"/>
                                </group>
                                <group>
                                    <field name="garage"/>
                                    <field name="garden"/>
                                    <field name="garden_area" invisible="not garden"/>
                                    <field name="garden_orientation" invisible="not garden"/>
                                    <field name="total_area" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- TAB 2: Other Info -->
                        <page string="Other Info">
                            <group string="Buyer &amp; Salesperson">
                                <group>
                                    <field name="buyer_id"/>
                                    <field name="user_id"/>
                                </group>
                                <group>
                                    <field name="company_id" readonly="1"/>
                                </group>
                            </group>
                            <group string="System Information">
                                <group>
                                    <field name="active"/>
                                    <field name="create_date" readonly="1"/>
                                    <field name="create_uid" readonly="1"/>
                                </group>
                                <group>
                                    <field name="write_date" readonly="1"/>
                                    <field name="write_uid" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- TAB 3: Offers -->
                        <page string="Offers">
                            <field name="offer_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- =========================== -->
    <!-- VIEWS FOR OFFERS            -->
    <!-- =========================== -->
    <record id="view_estate_property_offer_list" model="ir.ui.view">
        <field name="name">estate.property.off  er.list</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <list string="Offers">
                <field name="price" sum="Total Offers" widget="monetary"/>
                <field name="partner_id"/>
                <field name="validity" string="Validity (days)"/>
                <field name="date_deadline"/>

                <button name="action_accept"
                        type="object"
                        icon="fa-check"
                        title="Accept"
                        invisible="status in ('accepted','refused')"/>

                <button name="action_refuse"
                        type="object"
                        icon="fa-times"
                        title="Refuse"
                        invisible="status in ('accepted','refused')"/>

                <field name="status" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_estate_property_offer_form" model="ir.ui.view">
        <field name="name">estate.property.offer.form</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <form string="Offer">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            Offer for <field name="property_id" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="price" widget="monetary"/>
                            <field name="partner_id"/>
                            <field name="validity" string="Validity (days)"/>
                            <field name="date_deadline"/>
                        </group>
                        <group>
                            <field name="status" widget="selection"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- =========================== -->
    <!-- ACTION                     -->
    <!-- =========================== -->
    <record id="action_estate_property" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first property!
            </p>
        </field>
    </record>

    <!-- =========================== -->
    <!-- VIEWS FOR TYPE & TAG       -->
    <!-- =========================== -->
    <record id="view_estate_property_type_list" model="ir.ui.view">
        <field name="name">estate.property.type.list</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <list string="Property Types">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_estate_property_type_form" model="ir.ui.view">
        <field name="name">estate.property.type.form</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <form string="Property Type">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>

                    <field name="property_ids">
                        <list>
                            <field name="name"/>
                            <field name="expected_price"/>
                            <field name="state"/>
                        </list>
                    </field>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_estate_property_type" model="ir.actions.act_window">
        <field name="name">Property Types</field>
        <field name="res_model">estate.property.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_estate_property_tag_list" model="ir.ui.view">
        <field name="name">estate.property.tag.list</field>
        <field name="model">estate.property.tag</field>
        <field name="arch" type="xml">
            <list string="Property Tags">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_estate_property_tag_form" model="ir.ui.view">
        <field name="name">estate.property.tag.form</field>
        <field name="model">estate.property.tag</field>
        <field name="arch" type="xml">
            <form string="Property Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_estate_property_tag" model="ir.actions.act_window">
        <field name="name">Property Tags</field>
        <field name="res_model">estate.property.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- =========================== -->
    <!-- MENUS                      -->
    <!-- =========================== -->
    <menuitem id="menu_estate_root" name="Real Estate" sequence="10"/>
    <menuitem id="menu_estate_first_level" name="Advertisements" parent="menu_estate_root" sequence="1"/>
    <menuitem id="menu_estate_property" name="Properties" parent="menu_estate_first_level" action="action_estate_property" sequence="1"/>

    <!-- Settings Menu -->
    <menuitem id="menu_estate_settings" name="Settings" parent="menu_estate_root" sequence="2"/>
    <menuitem id="menu_estate_property_type" name="Property Types" parent="menu_estate_settings" action="action_estate_property_type" sequence="1"/>
    <menuitem id="menu_estate_property_tag" name="Property Tags" parent="menu_estate_settings" action="action_estate_property_tag" sequence="2"/>
</odoo>