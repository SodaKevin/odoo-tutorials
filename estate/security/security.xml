<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_real_estate_brokerage" model="ir.module.category">
        <field name="name">Real Estate/Brokerage</field>
        <field name="description">Real Estate Brokerage Management</field>
        <field name="sequence">10</field>
    </record>

    <record id="estate_group_user" model="res.groups">
        <field name="name">Agent</field>
        <field name="category_id" ref="estate.module_category_real_estate_brokerage"/>
    </record>

    <record id="estate_group_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="estate.module_category_real_estate_brokerage"/>
        <field name="implied_ids" eval="[(4, ref('estate.estate_group_user'))]"/>
    </record>

    <record id="estate_property_company_rule" model="ir.rule">
        <field name="name">Property: multi-company</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">[
            '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids)
        ]</field>
        <field name="global" eval="True"/>
    </record>
</odoo>